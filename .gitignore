# ============================================================
#  Track ONLY the files the site needs to run.
# ============================================================

# ---- Videos ----
# Ignore everything in videos/, then re-include ONLY the two
# web-optimized clips the page actually plays. This keeps the
# large source/unused footage (30–45 MB each) out of the repo.
videos/*
!videos/wedding-mobile.mp4
!videos/wedding-540.mp4
!videos/wedding-720.mp4
!videos/wedding-1080.mp4
!videos/wedding-bg.mp4
!videos/wedding-music.m4a
!videos/poster.jpg

# ---- Project notes (not needed to run the site) ----
video.info.txt
# (videos/timing.txt is already excluded by videos/* above)

# ---- Dependencies / build / temp ----
node_modules/
*.log
npm-debug.log*

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.vscode/
.idea/

# ---- Local Claude Code config / memory ----
.claude/
